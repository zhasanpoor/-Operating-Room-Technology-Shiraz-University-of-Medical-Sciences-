# ── نمونهٔ متغیرهای محیطی ──────────────────────────────────────────
# این فایل را به نام `.env` کپی کنید و مقادیر را پر کنید.
# فایل `.env` هرگز نباید در گیت commit شود.

# پورتی که سرور روی آن اجرا می‌شود
PORT=3000

# مسیر فایل دیتابیس SQLite
DB_PATH=./database.sqlite

# کلید امضای توکن‌های ورود — حداقل ۳۲ کاراکتر تصادفی.
# در حالت production بدون این مقدار سرور بالا نمی‌آید.
# برای ساختن یک مقدار امن:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# محیط اجرا: development یا production
NODE_ENV=development

# دامنه‌های مجاز برای CORS، جداشده با کاما.
# اگر خالی بماند، در حالت توسعه همه‌چیز مجاز و در production فقط same-origin است.
# مثال: https://ort-shiraz.onrender.com,https://example.com
ALLOWED_ORIGINS=

# اطلاعات اولین حساب مدیر که هنگام seed ساخته می‌شود.
# پس از اولین ورود حتماً رمز را عوض کنید.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
